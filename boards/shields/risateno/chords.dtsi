// chords.dtsi

combo_enter {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp RET>;
    key-positions = <BLM BLI>;
    layers = <COMBO_LAYERS>;
};

combo_esc {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp ESC>;
    key-positions = <TLI LIT>;
    layers = <COMBO_LAYERS>;
};

combo_email {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&macro_email>;
    key-positions = <LOT LIT>;
    layers = <COMBO_LAYERS>;
};

combo_bootloader {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&bootloader>;
    key-positions = <TLP LIT>;
    layers = <0>;
};

// Bluetooth
combo_bt0 {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&bt BT_SEL 0>;
    key-positions = <BLP LIT>;
    layers = <COMBO_LAYERS>;
};

combo_bt1 {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&bt BT_SEL 1>;
    key-positions = <BLR LIT>;
    layers = <COMBO_LAYERS>;
};

combo_bt_clear {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&bt BT_CLR>;
    key-positions = <BLI BLR>;
    layers = <COMBO_LAYERS>;
};