combo_ctrl_a {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp LC(A)>;
    key-positions = <TLR TLM>;
    layers = <COMBO_LAYERS>;
};
combo_ctrl_c {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp LC(C)>;
    key-positions = <TLM TLI>;
    layers = <COMBO_LAYERS>;
};
combo_ctrl_v {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp LC(V)>;
    key-positions = <BLP BLR>;
    layers = <COMBO_LAYERS>;
};
combo_ctrl_x {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp LC(X)>;
    key-positions = <BLM BLI>;
    layers = <COMBO_LAYERS>;
};
combo_ctrl_z {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp LC(Z)>;
    key-positions = <LOT LIT>;
    layers = <COMBO_LAYERS>;
};
combo_esc {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp ESC>;
    key-positions = <TLP BLP>;
    layers = <COMBO_LAYERS>;
};
combo_win_space {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp LGUI &kp SPACE>;  // Win+Space
    key-positions = <TLP LIT>;
    layers = <COMBO_LAYERS>;
};
combo_l_B {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp B>;
    key-positions = <TLP LIT>;
    layers = <COMBO_LAYERS>;
};
combo_l_C {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp C>;
    key-positions = <TLR LIT>;
    layers = <COMBO_LAYERS>;
};
combo_l_V {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp V>;
    key-positions = <TLM LIT>;
    layers = <COMBO_LAYERS>;
};

combo_l_X {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp X>;
    key-positions = <BLR LIT>;
    layers = <COMBO_LAYERS>;
};

combo_l_Z {
    timeout-ms = <COMBO_TIMEOUT>;
    bindings = <&kp Z>;
    key-positions = <BLP LIT>;
    layers = <COMBO_LAYERS>;
};